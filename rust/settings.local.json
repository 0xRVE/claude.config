{
  "permissions": {
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/tmp",
      "/private/tmp"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git commit)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git clean *)",
      "Bash(git push *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)"
    ],
    "allow": [
      "Bash(sed -n *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cargo *)",
      "Bash(rustc *)",
      "Bash(rustup *)",
      "Bash(cmake *)",
      "Bash(ninja *)",
      "Bash(make *)",
      "Bash(ctest *)",
      "Bash(python3 *)",
      "Bash(deno *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(jq *)",
      "Bash(xxd *)",
      "Bash(zepter *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checkout *)",
      "Bash(gh pr list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh search *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git grep *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git merge-base *)",
      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:eips.ethereum.org)",
      "WebFetch(domain:eip.directory)",
      "WebFetch(domain:docs.polkadot.com)",
      "WebFetch(domain:api.github.com)",
      "Read(/tmp/**)",
      "Read(/private/tmp/**)",
    ],
    "deny": []
  },
  "enabledPlugins": {
    "rust-skills@rust-skills": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "rust-skills": {
      "source": {
        "source": "github",
        "repo": "actionbook/rust-skills"
      }
    }
  },
  "theme": "auto",
  "skipAutoPermissionPrompt": false
}

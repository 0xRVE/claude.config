{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(cd /Users/robert/code/*)",
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(find *)",
      "Bash(fd *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed -n *)",
      "Bash(awk *)",
      "Bash(cut *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(xargs *)",
      "Bash(jq *)",

      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(python3 *)",
      "Bash(node *)",

      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git diff *)",
      "Bash(git diff-index *)",
      "Bash(git diff-tree *)",
      "Bash(git ls-files *)",
      "Bash(git grep *)",
      "Bash(git blame *)",
      "Bash(git rev-list *)",
      "Bash(git merge-base *)",
      "Bash(git name-rev *)",
      "Bash(git symbolic-ref *)",
      "Bash(git reflog *)",
      "Bash(git submodule status *)",
      "Bash(git fetch *)",

      "Bash(gh auth status *)",
      "Bash(gh repo view *)",
      "Bash(gh repo list *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(gh api *)"
    ],
    "ask": [
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git apply *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh issue create *)",
      "Bash(gh issue edit *)"
    ],
    "additionalDirectories": ["/tmp"]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "denyWrite": ["."]
    }
  }
}